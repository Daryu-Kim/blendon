rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    function myProfile() {
      return signedIn() ? userDoc(request.auth.uid) : {};
    }

    function tokenRole() {
      return signedIn() && request.auth.token.role != null ? request.auth.token.role : 'customer';
    }

    function profileRole() {
      return signedIn() && myProfile().role != null ? myProfile().role : 'customer';
    }

    function isAdmin() {
      return signedIn()
        && (tokenRole() in ['manager', 'admin', 'owner']
          || profileRole() in ['manager', 'admin', 'owner']);
    }

    function gradeLevel(grade) {
      return grade == 'PUBLIC' || grade == null ? 0
        : exists(/databases/$(database)/documents/gradeBenefits/$(grade))
        ? get(/databases/$(database)/documents/gradeBenefits/$(grade)).data.level
        : grade == 'BLACK' ? 10
        : grade == 'VIP' ? 8
        : grade == 'PRO' ? 5
        : grade == 'PLUS' ? 3
        : 1;
    }

    function userGradeLevel() {
      return signedIn() && myProfile().userGradeLevel is number
        ? myProfile().userGradeLevel
        : signedIn() && myProfile().userGrade != null
          ? gradeLevel(myProfile().userGrade)
          : 0;
    }

    function requiredGradeLevel(data) {
      return data.minUserGradeLevel is number
        ? data.minUserGradeLevel
        : gradeLevel(data.minUserGradeToView);
    }

    function displayRequiredGradeLevel(data) {
      return gradeLevel(
        data.displayMinUserGradeToView != null
          ? data.displayMinUserGradeToView
          : 'PUBLIC'
      );
    }

    function isPublicCatalogDoc(data) {
      return requiredGradeLevel(data) == 0;
    }

    function isAdultVerified() {
      return signedIn() && myProfile().isAdultVerified == true;
    }

    function canViewCatalogDoc(data) {
      return data.isVisible == true
        && !(data.status in ['hidden', 'deleted'])
        && (data.isAdultOnly != true || isAdultVerified() || isPublicCatalogDoc(data))
        && userGradeLevel() >= requiredGradeLevel(data);
    }

    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow create: if signedIn() && request.auth.uid == uid && request.resource.data.role == 'customer';
      allow update: if signedIn()
        && request.auth.uid == uid
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'userGrade', 'userGradeLevel', 'isAdultVerified', 'adultVerifiedAt', 'adultVerificationProvider', 'totalPurchaseAmount']);
      allow update, delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if isAdmin() || canViewCatalogDoc(resource.data);
      allow create, update, delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if isAdmin() || resource.data.isVisible == true
        && userGradeLevel() >= displayRequiredGradeLevel(resource.data);
      allow create, update, delete: if isAdmin();
    }

    match /gradeBenefits/{gradeId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /storeSettings/{settingId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /siteSettings/{settingId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow create, delete: if false;
    }

    match /cartItems/{cartItemId} {
      allow read, delete: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if signedIn() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
    }

    match /banners/{bannerId} {
      allow read: if resource.data.isActive == true || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /notices/{noticeId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /noticePopups/{popupId} {
      allow read: if resource.data.isActive == true || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /inquiries/{inquiryId} {
      allow read: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if signedIn()
        && ((resource.data.userId == request.auth.uid && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['answer', 'answeredAt']))
        || isAdmin());
      allow delete: if isAdmin();
    }

    match /adultVerificationLogs/{logId} {
      allow read: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create, update, delete: if false;
    }

    match /admin/{docId} {
      allow read, write: if isAdmin();
    }

    match /adminAuditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
