rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function role() {
      return signedIn() && request.auth.token.role != null ? request.auth.token.role : 'customer';
    }

    function isAdmin() {
      return signedIn() && role() in ['manager', 'admin', 'owner'];
    }

    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() && request.resource.size < 10 * 1024 * 1024 && request.resource.contentType.matches('image/.*');
    }

    match /banners/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() && request.resource.size < 10 * 1024 * 1024 && request.resource.contentType.matches('image/.*');
    }

    match /notices/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() && request.resource.size < 10 * 1024 * 1024 && request.resource.contentType.matches('image/.*');
    }

    match /notice-popups/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() && request.resource.size < 10 * 1024 * 1024 && request.resource.contentType.matches('image/.*');
    }

    match /seo/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() && request.resource.size < 10 * 1024 * 1024 && request.resource.contentType.matches('image/.*');
    }

    match /uploads/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() && request.resource.size < 10 * 1024 * 1024 && request.resource.contentType.matches('image/.*');
    }

    match /admin/{allPaths=**} {
      allow read, write: if isAdmin();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
