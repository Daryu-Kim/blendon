# Public Firebase client config
NUXT_PUBLIC_FIREBASE_API_KEY=
NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NUXT_PUBLIC_FIREBASE_PROJECT_ID=
NUXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NUXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NUXT_PUBLIC_FIREBASE_APP_ID=
NUXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Server-only secrets. Never expose these with NUXT_PUBLIC_.
APICK_AUTH_KEY=
FIREBASE_SERVICE_ACCOUNT_JSON=
ADMIN_INITIAL_EMAIL=

# Route SMS through Firebase Functions instead of this Nuxt server.
PPURIO_FUNCTION_URL=
PPURIO_FUNCTION_SECRET=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Optional deployment/runtime controls
NUXT_PUBLIC_APP_ENV=local
NUXT_PUBLIC_ENABLE_MOCK_AUTH=false
NUXT_PUBLIC_ENABLE_MOCK_PAYMENTS=false
